{
    "name": "visionquest/claude-scraper",
    "description": "Utility platform to scrape restaurant menus and inventory",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "J.J. Johnson",
            "email": "visionquest716@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/dom-crawler": "^6.0",
        "symfony/css-selector": "^6.0",
        "php-webdriver/webdriver": "^1.14",
        "thiagoalessio/tesseract_ocr": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
