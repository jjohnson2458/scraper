RewriteEngine On

# Redirect to front controller if file/directory doesn't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(env|md|txt|json|lock|xml)$">
    Require all denied
</FilesMatch>
